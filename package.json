{
  "name": "finance-tracker",
  "version": "1.0.0",
  "description": "Offline desktop personal finance tracker (Electron + React + SQLite).",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron": "electron .",
    "build": "vite build",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "googleapis": "^156.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^32.1.0",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
